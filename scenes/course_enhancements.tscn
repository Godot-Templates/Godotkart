[sub_resource type="Shader" id="Shader_806c2"]
code = "shader_type spatial;
render_mode cull_disabled;

float hash(vec2 p) { return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123); }

void fragment() {
    float grain = hash(floor(UV * vec2(34.0, 58.0)));
    float rut_a = 1.0 - smoothstep(0.035, 0.078, abs(UV.x - 0.37));
    float rut_b = 1.0 - smoothstep(0.035, 0.078, abs(UV.x - 0.63));
    float rut = clamp(rut_a + rut_b, 0.0, 1.0);
    float dusty_lip = smoothstep(0.58, 0.97, UV.y);
    vec3 packed_dirt = vec3(0.55, 0.34, 0.15);
    vec3 dry_dirt = vec3(0.82, 0.60, 0.33);
    vec3 dark_rut = vec3(0.28, 0.16, 0.07);
    vec3 color = mix(packed_dirt, dry_dirt, dusty_lip);
    color *= 0.92 + grain * 0.14;
    ALBEDO = mix(color, dark_rut, rut * 0.48);
    ROUGHNESS = 1.0;
}
"

